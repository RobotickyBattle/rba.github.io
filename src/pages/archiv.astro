---

import MainLayout from "../layouts/MainLayout.astro"
import ArchiveCard from "../components/ArchiveCard.astro"

const img = (year: string) => `${import.meta.env.BASE_URL}archive/${year}.jpg`;
---

<MainLayout title="Archív">
	<secition class="content py-12 flex flex-col space-y-2">
		<h1>Archív</h1>
		<p>
			Chýba vám už RBA, hľadáte inšpiráciu, alebo sa už len neviete dočkať ďalšieho ročníka? Prezrite si galérie z minulých rokov!
		</p>
		<div class="w-full gap-4 grid grid-cols-1 md:grid-cold-2 lg:grid-cols-3">
			<ArchiveCard 
				title="RBA 2026" 
				imgPath={img("2026")} 
				albumLink="https://photos.app.goo.gl/bGM8bswc5AVyLmGz7" 
				resultsLink="https://github.com/RobotickyBattle/rba.github.io/tree/master/public/pdf/results/2026-Vysledky.pdf" />
			<ArchiveCard 
				title="RBA 2025" 
				imgPath={img("2025")} 
				albumLink="https://photos.app.goo.gl/FRv3Ykto8BwhSW9r5" 
				resultsLink="https://github.com/RobotickyBattle/rba.github.io/tree/master/public/pdf/results/2025-Vysledky.pdf" />
			<ArchiveCard 
				title="RBA 2024" 
				imgPath={img("2024")} 
				albumLink="https://photos.app.goo.gl/SBa7oX8Lk1VtxJVq9" 
				resultsLink="https://github.com/RobotickyBattle/rba.github.io/tree/master/public/pdf/results/2024-Vysledky.pdf" />
			<ArchiveCard 
				title="RBA 2023" 
