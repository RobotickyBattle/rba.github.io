				resultsLink="https://github.com/RobotickyBattle/rba.github.io/tree/master/public/pdf/results/2023-Vysledky.pdf" />
			<ArchiveCard 
				title="RBA 2022" 
				imgPath={img("2022")} 
				albumLink="https://photos.app.goo.gl/p3XBnPog3AaquoqK7" 
				resultsLink="https://github.com/RobotickyBattle/rba.github.io/tree/master/public/pdf/results/2022-Vysledky.pdf" />
			<ArchiveCard 
				title="RBA 2019" 
				imgPath={img("2019")} 
