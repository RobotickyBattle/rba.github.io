---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt?: string;
	class?: string;
	widths?: number[];
	sizes?: string;
	quality?: number;
	loading?: 'lazy' | 'eager';
	fetchpriority?: 'high' | 'low' | 'auto';
	objectPosition?: string;
}

const {
	src,
	alt = '',
	class: className = '',
	widths = [640, 960, 1280],
	sizes = '100vw',
	quality = 65,
	loading = 'lazy',
	fetchpriority = 'auto',
	objectPosition = 'center',
} = Astro.props;

const maxWidth = Math.max(...widths);
---

<Image
	src={src}
	alt={alt}
	class={`absolute inset-0 w-full h-full object-cover ${className}`}
	style={objectPosition !== 'center' ? { objectPosition } : undefined}
	width={maxWidth}
	widths={widths}
	sizes={sizes}
	format="webp"
	quality={quality}
	loading={loading}
	fetchpriority={fetchpriority}
	decoding="async"
/>
