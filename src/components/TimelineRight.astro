---
 const {img, title, time, desc} = Astro.props;
---

<div
    class="relative flex items-center justify-between md:flex-row-reverse w-full"
>
    <!-- Photo on desktop (left side) -->
    <div
        class="hidden md:block md:w-5/12 h-52 overflow-hidden"
    >
        <img
            src={img}
            alt={title}
            class="w-full h-full object-cover"
        />
    </div>
    <div
        class="z-10 absolute left-4 md:left-1/2 transform -translate-x-1/2 w-8 h-8 bg-orange border-4 border-white rounded-full shadow"
    >
    </div>
    <div
        class="ml-12 md:ml-0 md:w-5/12 bg-white p-6 shadow-md border-l-4 l:border-l-0 l:border-r-4 border-orangeLight transition hover:shadow-xl"
    >
        <span class="text-orange font-black">{time}</span>
        <h3 class="text-lg font-bold text-blue mb-1">{title}</h3>
        <p class="text-subtext text-sm">
            {desc}
        </p>
    </div>
</div>
