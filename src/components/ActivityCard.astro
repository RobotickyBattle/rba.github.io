---
const { title, imgPath, desc, time, place } = Astro.props
---

<div class="w-full bg-white shadow-sm flex flex-col space-y-4">
    <div class="w-full h-64 bg-cover bg-no-repeat bg-center" style={{backgroundImage: `url('${imgPath}')`,}}>

    </div>
    <h3 class="text-orange px-4">{title}</h3>
    <p class="px-4 text-subtext">
        {desc}
    </p>
    <div class="flex flex-col space-y-2 px-4 pb-4">
        <div class="flex flex-row space-x-2 items-center">
            <span class="material-symbols-outlined text-orange">
                 schedule
            </span>
            <p>
                {time}
            </p>
        </div>
        <div class="flex flex-row space-x-2 items-center">
            <span class="material-symbols-outlined text-orange">
                 pin_drop
            </span>
            <p>
                {place}
            </p>
        </div>
    </div>
</div>